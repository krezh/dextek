{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    "local>krezh/renovate-config",
    ".renovate/autoMerge.json5",
    ".renovate/allowedVersions.json5",
    ".renovate/groups.json5",
    ".renovate/customManagers.json5",
    ".renovate/packageRules.json5",
    ".renovate/clusters.json5",
    ".renovate/grafanaDashboards.json5",
    ".renovate/overrides.json5",
  ],
  flux: {
    managerFilePatterns: ["/clusters/.+\\.ya?ml$/"],
  },
  "helm-values": {
    managerFilePatterns: ["/clusters/.+\\.ya?ml$/"],
  },
  kubernetes: {
    managerFilePatterns: ["/clusters/.+\\.ya?ml$/"],
  },
}
