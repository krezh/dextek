{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    "local>krezh/renovate-config",
    "local>krezh/dextek//.renovate/autoMerge.json5",
    "local>krezh/dextek//.renovate/allowedVersions.json5",
    "local>krezh/dextek//.renovate/groups.json5",
    "local>krezh/dextek//.renovate/packageRules.json5",
    "local>krezh/dextek//.renovate/clusters.json5",
  ],
  flux: {
    managerFilePatterns: ["/clusters/.+\\.ya?ml$/"],
  },
  "helm-values": {
    managerFilePatterns: ["/clusters/.+\\.ya?ml$/"],
  },
  kubernetes: {
    managerFilePatterns: ["/clusters/.+\\.ya?ml$/"],
  },
}
