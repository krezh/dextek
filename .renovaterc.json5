{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    "local>dextek/renovate-config",
    "local>dextek/dextek//.renovate/autoMerge.json5",
    "local>dextek/dextek//.renovate/allowedVersions.json5",
    "local>dextek/dextek//.renovate/groups.json5",
    "local>dextek/dextek//.renovate/customManagers.json5",
    "local>dextek/dextek//.renovate/packageRules.json5",
    "local>dextek/dextek//.renovate/clusters.json5",
    "local>dextek/dextek//.renovate/grafanaDashboards.json5",
    "local>dextek/dextek//.renovate/overrides.json5",
  ],
  flux: {
    managerFilePatterns: ["/clusters/.+\\.ya?ml$/"],
  },
  "helm-values": {
    managerFilePatterns: ["/clusters/.+\\.ya?ml$/"],
  },
  kubernetes: {
    managerFilePatterns: ["/clusters/.+\\.ya?ml$/"],
  },
}
