{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  packageRules: [
    {
      description: "Flux Operator Group",
      groupName: "flux-operator",
      matchDatasources: ["docker"],
      matchPackageNames: [
        "/flux-operator/",
        "/flux-instance/",
        "/flux-operator-manifests/",
      ],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
      minimumGroupSize: 3,
    },
    {
      description: "Tofu-Controller Images and tags",
      groupName: "Tofu-Controller",
      matchPackageNames: ["tofu-controller"],
      matchDatasources: ["docker", "github-tags"],
      versioning: "semver",
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
    },
    {
      description: "Immich Images",
      groupName: "Immich",
      matchPackageNames: ["/immich/"],
      matchDatasources: ["docker", "github-releases"],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
      sourceUrl: "https://github.com/immich-app/immich",
    },
    {
      description: "Rook-Ceph charts and image",
      groupName: "Rook-Ceph",
      matchPackageNames: ["rook.ceph"],
      matchDatasources: ["helm", "docker"],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
    },
    {
      description: "Talos Group",
      groupName: "Talos",
      matchPackageNames: ["/installer/", "/talosctl/", "siderolabs/talos"],
      matchDatasources: ["docker", "github-releases", "custom.talos-factory"],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
      sourceUrl: "https://github.com/siderolabs/talos",
    },
    {
      description: "Kubernetes Group",
      groupName: "Kubernetes",
      matchPackageNames: [
        "/kube-apiserver/",
        "/kube-controller-manager/",
        "/kube-proxy/",
        "/kube-scheduler/",
        "/kubelet/",
      ],
      matchDatasources: ["docker", "github-releases"],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
      sourceUrl: "https://github.com/kubernetes/kubernetes",
    },
    {
      description: "Maintainerr Images",
      groupName: "Maintainerr",
      matchPackageNames: ["maintainerr"],
      matchDatasources: ["docker", "github-releases"],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
      sourceUrl: "https://github.com/jorenn92/Maintainerr",
    },
    {
      description: "Radarr Images",
      groupName: "Radarr",
      matchPackageNames: ["radarr"],
      matchDatasources: ["docker", "github-releases"],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
      sourceUrl: "https://github.com/radarr/radarr",
    },
    {
      description: ["Volsync Group"],
      groupName: "Volsync",
      matchPackageNames: ["volsync"],
      matchDatasources: ["docker", "helm"],
      matchUpdateTypes: ["minor", "patch"],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
    },
    {
      description: ["Authentik Group"],
      groupName: "Authentik",
      matchPackageNames: ["/authentik/"],
      matchDatasources: ["docker", "helm", "github-releases"],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
      sourceUrl: "https://github.com/goauthentik/authentik",
      versioning: "regex:^(?:version/)?(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)$",
      prBodyNotes: "Changelog: https://docs.goauthentik.io/docs/releases/{{newMajor}}.{{newMinor}}#fixed-in-{{newMajor}}{{newMinor}}{{newPatch}}",
    },
    {
      description: ["Dragonfly Operator Group"],
      groupName: "Dragonfly Operator",
      matchPackageNames: [
        "dragonflydb/operator",
        "dragonflydb/dragonfly-operator",
      ],
      matchDatasources: ["docker", "helm", "github-releases"],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
      sourceUrl: "https://github.com/dragonflydb/dragonfly-operator",
    },
    {
      description: ["Zipline Group"],
      groupName: "Zipline",
      matchPackageNames: ["/zipline/"],
      matchDatasources: ["docker", "helm", "github-releases"],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
      sourceUrl: "https://github.com/diced/zipline",
    },
    {
      description: ["Atuin Group"],
      groupName: "Atuin",
      matchPackageNames: ["/atuin/"],
      matchDatasources: ["docker", "helm", "github-releases"],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
      sourceUrl: "https://github.com/atuinsh/atuin",
    },
    {
      description: ["Envoy Group"],
      groupName: "Envoy",
      matchPackageNames: ["/envoyproxy/envoy/"],
      matchDatasources: ["docker", "github-releases"],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
      sourceUrl: "https://github.com/envoyproxy/envoy",
    },
    {
      description: ["Jellyfin Group"],
      groupName: "Jellyfin",
      matchPackageNames: ["/jellyfin/"],
      matchDatasources: ["docker", "github-releases"],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
      sourceUrl: "https://github.com/jellyfin/jellyfin",
    },
    {
      description: ["Towonel Group"],
      groupName: "Towonel",
      matchPackagePatterns: [
        "eleboucher/towonel-agent$",
        "eleboucher/towonel-node$",
      ],
      matchDatasources: ["docker"],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
      sourceUrl: "https://git.erwanleboucher.dev/eleboucher/towonel",
    },
  ],
}
