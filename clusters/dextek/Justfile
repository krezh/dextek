#!/usr/bin/env just --justfile

set quiet
set positional-arguments
set lazy

CLUSTER_DIR := "."
BOOTSTRAP_DIR := CLUSTER_DIR + "/bootstrap"
TALOS_CONTROLLER := "$(talosctl config info --output json | jq --raw-output '.endpoints[]' | shuf -n 1)"
CLUSTER_NAME := "dextek"

_default:
    just --list

[private]
step desc command:
    #!/usr/bin/env bash
    STEP_CMD={{ quote(command) }}
    gum spin --show-error --spinner dot --title "{{ desc }}" -- bash -c "$STEP_CMD" || exit 1
    printf '\r\e[2K\e[32m✓\e[0m %s\n' "{{ desc }}"

# Bootstrap all resources
all:
    #!/usr/bin/env bash
    set -euo pipefail
    gum confirm "Bootstrap cluster {{ CLUSTER_NAME }}?" || exit 0
    printf '%.0s─' $(seq 1 24); echo
    just tofu
    just talosconfig
    just talos
    just kubeconfig
    just readyCheck
    just namespaces
    just crds
    just apps
    just flux-secrets
    just wipe
    just k9s

tofu:
    #!/usr/bin/env bash
    init='cd "{{ CLUSTER_DIR }}/terraform/talos" && tofu init --upgrade'
    apply='cd "{{ CLUSTER_DIR }}/terraform/talos" && tofu apply --auto-approve --var talosconfig=true'
    just step "Initialising Tofu" "${init}"
    just step "Applying Tofu" "${apply}"
    mkdir -p ~/.talos/configs
    cp "{{ CLUSTER_DIR }}/terraform/talos/talosconfig" ~/.talos/configs/{{ CLUSTER_NAME }}

talosconfig:
    #!/usr/bin/env bash
    cmd="talswitcher ctx {{ CLUSTER_NAME }}"
    just step "Switching talos context" "${cmd}"

talos:
    #!/usr/bin/env bash
    CTRL="{{ TALOS_CONTROLLER }}"
    cmd="until talosctl --nodes $CTRL bootstrap; do sleep 5; done"
    just step "Bootstrapping $CTRL" "${cmd}"

kubeconfig:
    #!/usr/bin/env bash
    CTRL="{{ TALOS_CONTROLLER }}"
    cmd="until talosctl kubeconfig -n $CTRL --force; do sleep 3; done && kubectl config set-cluster {{ CLUSTER_NAME }} --server https://$CTRL:6443"
    just step "Getting kubeconfig" "${cmd}"

readyCheck:
    #!/usr/bin/env bash
    cmd="until kubectl wait nodes --for=condition=Ready=False --all --timeout=10m; do sleep 5; done"
    just step "Waiting for nodes" "${cmd}"

namespaces:
    #!/usr/bin/env bash
    cmd='find apps -mindepth 1 -maxdepth 1 -type d | while IFS= read -r dir; do kustomize build "$dir" | yq ea -e '\''select(.kind == "Namespace")'\'' | kubectl apply --server-side --field-manager bootstrap --force-conflicts -f - 2>/dev/null || true; done'
    just step "Applying namespaces" "${cmd}"

flux-secrets:
    #!/usr/bin/env bash
    cmd="infisical export --template={{ BOOTSTRAP_DIR }}/resources.yaml.tmpl | kubectl apply -f -"
    just step "Applying Flux secrets" "${cmd}"

crds:
    #!/usr/bin/env bash
    cmd='until helmfile -f {{ BOOTSTRAP_DIR }}/helmfile.d/00-crds.yaml template -q | yq ea -e "select(.kind == \"CustomResourceDefinition\")" | kubectl apply --server-side --field-manager bootstrap --force-conflicts -f -; do sleep 3; done'
    just step "Applying CRDs" "${cmd}"

apps:
    #!/usr/bin/env bash
    cmd='until helmfile -f {{ BOOTSTRAP_DIR }}/helmfile.d/01-apps.yaml sync --hide-notes; do sleep 3; done'
    just step "Deploying apps" "${cmd}"

helmfile: crds apps

wipe:
    #!/usr/bin/env bash
    kubectl delete daemonset disk-wipe -n kube-system --ignore-not-found >/dev/null 2>&1
    apply="kubectl apply -f {{ BOOTSTRAP_DIR }}/wipe-daemonset.yaml"
    rollout="kubectl rollout status daemonset/disk-wipe -n kube-system --timeout=10m"
    just step "Applying wipe DaemonSet" "${apply}"
    just step "Wiping disks" "${rollout}"
    kubectl delete daemonset disk-wipe -n kube-system --ignore-not-found >/dev/null 2>&1

k9s:
    #!/usr/bin/env bash
    LAYOUT=$(cat << 'EOF'
    layout {
        pane split_direction="vertical" {
            pane split_direction="horizontal" {
                pane {
                    command "k9s"
                    args "--all-namespaces" "--command" "kustomizations"
                }
                pane {
                    command "k9s"
                    args "--all-namespaces" "--command" "pods"
                }
            }
            pane split_direction="horizontal" {
                pane {
                    command "k9s"
                    args "--all-namespaces" "--command" "helmreleases"
                }
                pane {
                    command "k9s"
                    args "--all-namespaces" "--command" "events"
                }
            }
        }
    }
    EOF
    )
    nix run nixpkgs#zellij -- --layout-string "$LAYOUT"
